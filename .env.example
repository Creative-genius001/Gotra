# ─── Core API ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
APP_ENV=development
APP_BASE_URL=http://localhost:3000

# ─── Tunnel Gateway ─────────────────────────────────────────
GATEWAY_PORT=8081
TUNNEL_BASE_DOMAIN=tunnels.gotra.local

# Production TLS (leave unset for plain HTTP in dev). Two options:
#  1) Static cert (e.g. a wildcard *.tunnels.gotra.dev):
# GATEWAY_TLS_CERT_FILE=/etc/gotra/tls/fullchain.pem
# GATEWAY_TLS_KEY_FILE=/etc/gotra/tls/privkey.pem
#  2) ACME autocert — issues a cert per tunnel hostname on demand (needs :443
#     reachable and DNS for *.TUNNEL_BASE_DOMAIN pointed at the gateway):
# GATEWAY_AUTOCERT_ENABLED=true
# GATEWAY_AUTOCERT_EMAIL=ops@yourdomain.com
# GATEWAY_AUTOCERT_CACHE_DIR=/var/lib/gotra/autocert

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=gotra
POSTGRES_PASSWORD=gotra
POSTGRES_DB=gotra
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full DSN consumed by the API
DATABASE_URL=postgres://gotra:gotra@localhost:5432/gotra?sslmode=disable

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── ClickHouse (optional analytics) ────────────────────────
# Leave empty to disable analytics. To enable, start the clickhouse profile
# (docker compose --profile analytics up -d) and set:
# CLICKHOUSE_URL=clickhouse://gotra:gotra@localhost:9000/gotra
CLICKHOUSE_URL=

# ─── Auth / JWT ─────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# ─── OAuth providers ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/auth/github/callback

# Enterprise SSO via generic OpenID Connect (Okta, Entra ID, Auth0, Keycloak…).
# Endpoints are auto-discovered from the issuer's /.well-known/openid-configuration.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/oidc/callback

# ─── AI Debugging Service ───────────────────────────────────
# Primary provider per spec is Gemini; Claude is secondary/fallback.
AI_PRIMARY_PROVIDER=gemini
AI_SECONDARY_PROVIDER=claude
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Billing (Stripe) ───────────────────────────────────────
# Leave STRIPE_SECRET_KEY empty to use the stub processor (immediate plan
# changes, no charge). When set, paid-plan changes return a Checkout URL and are
# applied via the webhook at POST /api/v1/billing/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# ─── Frontend (apps/web) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
